import pandas as pd
import matplotlib.pyplot as plt
from io import StringIO

# ---- CSV einlesen (hier einfach dein Text einfügen) ----
# Entweder Pfad zur CSV oder ein CSV-Inhalt als Text
import os

data = r"C:\Users\ThinkPad\Nextcloud\Studium\Masterarbeit\Code\Eigene daten\PyPSA_2045_backup_capacity_alle-Scenarios.csv"

if os.path.exists(data):
    df = pd.read_csv(data)
else:
    df = pd.read_csv(StringIO(data))

if "variable" not in df.columns:
    raise ValueError("Spalte 'variable' fehlt in der CSV: gefundene Spalten sind " + ",".join(df.columns))

# ---- Jahr auswählen ----
year = "2045"

# ---- relevante Technologien filtern ----
df = df[df["variable"].str.contains("Capacity|Electricity")]

# ---- Funktion zum Klassifizieren ----
def classify(row):
    var = row["variable"]
    
    if "Gas" in var:
        if "w/ CCS" in var:
            return "gas_ccs"
        else:
            return "gas_no_ccs"
    
    if "Hydrogen" in var:
        return "hydrogen"
    
    return None

df["group"] = df.apply(classify, axis=1)
df = df.dropna(subset=["group"])

# ---- Aggregation ----
grouped = (
    df.groupby(["model", "scenario", "group"])[year]
    .sum()
    .unstack(fill_value=0)
)

# fehlende Spalten ergänzen
for col in ["gas_no_ccs", "gas_ccs", "hydrogen"]:
    if col not in grouped.columns:
        grouped[col] = 0

# ---- Labels bauen ----
# Nur die Szenario-Kürzel verwenden, Modellteil (z.B. pypsa-de vxx) weglassen
grouped["label"] = grouped.index.get_level_values(1)
grouped = grouped.reset_index(drop=True)

# ---- Plot ----
fig, ax = plt.subplots(figsize=(10,6))

x = range(len(grouped))

# Farben
color_gas = "#f28e2b"        # orange
color_gas_ccs = "#f7c79e"    # helleres orange
color_h2 = "#4ecdc4"         # türkis

# Stapeln
bottom = [0]*len(grouped)

ax.bar(x, grouped["gas_no_ccs"], label="Gas (ohne CCS)", bottom=bottom, color=color_gas)
bottom = grouped["gas_no_ccs"]

ax.bar(x, grouped["gas_ccs"], label="Gas (mit CCS)", bottom=bottom, color=color_gas_ccs)
bottom = bottom + grouped["gas_ccs"]

ax.bar(x, grouped["hydrogen"], label="Wasserstoff", bottom=bottom, color=color_h2)

# Achsen & Labels
ax.set_xticks(x)
ax.set_xticklabels(grouped["label"], rotation=0, ha="center")

ax.set_ylabel("Kapazität [GW]")
ax.set_title(f"Gesicherte Leistung laut PyPSA-DE v0.1.1 nach Szenario {year}", fontsize=18)

ax.legend()
ax.grid(axis="y")

plt.tight_layout()
plt.show()

