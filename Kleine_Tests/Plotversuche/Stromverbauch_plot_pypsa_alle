import pandas as pd
import matplotlib.pyplot as plt
from io import StringIO

# ---- CSV einlesen (hier einfach dein Text einfügen) ----
# Entweder Pfad zur CSV oder ein CSV-Inhalt als Text
import os

data = r"C:\Users\ThinkPad\Nextcloud\Studium\Masterarbeit\Code\Eigene daten\Stromverbrauch_2045_PyPSA_alle.csv"

if os.path.exists(data):
    df = pd.read_csv(data)
else:
    df = pd.read_csv(StringIO(data))

if "variable" not in df.columns:
    raise ValueError("Spalte 'variable' fehlt in der CSV: gefundene Spalten sind " + ",".join(df.columns))

# ---- Jahr auswählen ----
year = "2045"

# ---- relevante Werte filtern ----
# Für Stromverbrauch braucht es keine Kapazitäts-Gruppierung, stattdessen nur Verbrauchsvariable
# optional: adjust filter to your exact variable name in CSV
df = df[df["variable"].str.contains("Electricity|Consumption|Load", case=False, na=False)]

if year not in df.columns:
    raise ValueError(f"Jahrsspalte '{year}' fehlt in der CSV: gefundene Spalten sind " + ",".join(df.columns))

# ---- Auswahl pro Szenario ----
# Wir erwarten pro model/scenario einen Wert in 2045, daher keine Stapelung nötig
grouped = (
    df.groupby(["model", "scenario"])[year]
    .first()
    .reset_index()
)

# ---- Labels bauen ----
# nur Szenarioname (keine Modellversion) als xtick-Beschriftung
grouped["label"] = grouped["scenario"]

# ---- Plot ----
fig, ax = plt.subplots(figsize=(9,5))

x = range(len(grouped))

ax.bar(x, grouped[year], color="#4e79a7")

# Achsen & Labels
ax.set_xticks(x)
ax.set_xticklabels(grouped["label"], rotation=0, ha="center")

ax.set_ylabel("Verbrauch [TWh]")
ax.set_title(f"Stromverbrauch nach Szenario (2045)", fontsize=18)

ax.grid(axis="y")

plt.tight_layout()
plt.show()

